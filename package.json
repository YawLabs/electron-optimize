{
  "name": "@yawlabs/electron-optimize",
  "version": "1.0.2",
  "description": "Drop-in optimization utilities for Electron apps — temp file cleanup, window bounds validation, startup timing, cache management, and power state handling.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/ test/",
    "lint:fix": "biome check --write src/ test/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "electron",
    "optimize",
    "performance",
    "cleanup",
    "window-bounds",
    "startup",
    "cache",
    "temp-files"
  ],
  "author": "Yaw Labs <hello@yaw.sh>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YawLabs/electron-optimize.git"
  },
  "bugs": {
    "url": "https://github.com/YawLabs/electron-optimize/issues"
  },
  "homepage": "https://github.com/YawLabs/electron-optimize",
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "electron": ">=20.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
